import org.springframework.beans.factory.annotation.Value;
import org.springframework.stereotype.Service;

import java.sql.Connection;
import java.sql.DriverManager;
import java.sql.SQLException;

@Service
public class ClickHouseConnectionService {

    private final String jdbcUrl;
    private final String username;
    private final String password;

    public ClickHouseConnectionService(
            @Value("${clickhouse.jdbc.url}") String jdbcUrl,
            @Value("${clickhouse.jdbc.username}") String username,
            @Value("${clickhouse.jdbc.password}") String password) {

        this.jdbcUrl = jdbcUrl;
        this.username = username;
        this.password = password;
    }

    public Connection getConnection() throws SQLException {
        return DriverManager.getConnection(jdbcUrl, username, password);
    }
}
