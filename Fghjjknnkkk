✅ Table CLEAN
SQL
CREATE TABLE job_monitoring
(
    run_id String,
    job_name String,
    event_type String,   -- START / END / METRIC
    event_time DateTime,

    status String,

    metric_name String,
    metric_value Float64,

    error_message String
)
ENGINE = MergeTree
ORDER BY (job_name, run_id, event_time);
