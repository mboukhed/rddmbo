        List<InputPartition> partitions = Files.walk(Paths.get(path))
                .filter(Files::isRegularFile)
                .filter(p -> p.toString().endsWith(".parquet"))
                .map(p -> (InputPartition) new FakeInputPartition(p.toString(), schema))
                .collect(Collectors.toList());

