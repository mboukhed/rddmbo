import org.apache.hadoop.fs.*;
import org.apache.spark.sql.*;
import org.apache.spark.sql.types.*;
import org.apache.spark.sql.functions;

import java.util.ArrayList;
import java.util.List;

public class AzurePartitionReader {

    public static Dataset<Row> readPartitionedDataset(
            SparkSession spark,
            String rootPath,
            StructType targetSchema
    ) throws Exception {

        List<String> partitions = listPartitions(spark, rootPath);

        Dataset<Row> union = null;

        for (String partition : partitions) {

            Dataset<Row> df = spark.read()
                    .format("parquet")
                    .load(partition);

            Dataset<Row> stringDf = castAllColumnsToString(df);

            if (union == null)
                union = stringDf;
            else
                union = union.unionByName(stringDf, true);
        }

        return applySchema(union, targetSchema);
    }

    /**
     * Liste les partitions dans ADLS
     */
    public static List<String> listPartitions(SparkSession spark, String path) throws Exception {

        FileSystem fs = FileSystem.get(
                new java.net.URI(path),
                spark.sparkContext().hadoopConfiguration()
        );

        List<String> partitions = new ArrayList<>();

        for (FileStatus status : fs.listStatus(new Path(path))) {

            if (status.isDirectory())
                partitions.add(status.getPath().toString());
        }

        return partitions;
    }

    /**
     * Cast toutes les colonnes en String
     */
    public static Dataset<Row> castAllColumnsToString(Dataset<Row> df) {

        Column[] cols = new Column[df.columns().length];

        for (int i = 0; i < df.columns().length; i++) {

            cols[i] = functions.col(df.columns()[i])
                    .cast(DataTypes.StringType)
                    .alias(df.columns()[i]);
        }

        return df.select(cols);
    }

    /**
     * Applique le schema final
     */
    public static Dataset<Row> applySchema(Dataset<Row> df, StructType schema) {

        Column[] cols = new Column[schema.fields().length];

        for (int i = 0; i < schema.fields().length; i++) {

            StructField f = schema.fields()[i];

            cols[i] = functions.col(f.name())
                    .cast(f.dataType())
                    .alias(f.name());
        }

        return df.select(cols);
    }
}
