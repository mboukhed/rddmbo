2. Exemple de test JUnit 5 avec spark.sql(...)
com/acme/test/ClickHouseSqlTest.java
Java
package com.acme.test;

import org.apache.spark.sql.Dataset;
import org.apache.spark.sql.Row;
import org.apache.spark.sql.SparkSession;
import org.junit.jupiter.api.AfterEach;
import org.junit.jupiter.api.Assertions;
import org.junit.jupiter.api.Test;

public class ClickHouseSqlTest {

    private SparkSession spark;

    @AfterEach
    void tearDown() {
        if (spark != null) {
            spark.stop();
        }
    }

    @Test
    void should_query_fake_clickhouse_catalog_with_sql() {
        spark = SparkSession.builder()
                .master("local[*]")
                .appName("test-clickhouse-sql")
                .config("spark.ui.enabled", "false")
                .config("spark.sql.catalog.clickhouse", "com.acme.test.FakeClickHouseCatalog")
                .getOrCreate();

        spark.sql("CREATE NAMESPACE IF NOT EXISTS clickhouse.mydb");

        spark.sql("DROP TABLE IF EXISTS clickhouse.mydb.users");

        spark.sql(
                "CREATE TABLE clickhouse.mydb.users (" +
                        "id INT, " +
                        "name STRING" +
                        ") USING parquet"
        );

        spark.sql(
                "INSERT INTO clickhouse.mydb.users VALUES " +
                        "(1, 'a'), " +
                        "(2, 'b')"
        );

        Dataset<Row> df = spark.sql("SELECT * FROM clickhouse.mydb.users");

        Assertions.assertEquals(2, df.count());
    }
}
