private static long int96ToMicros(byte[] bytes) {
    if (bytes == null || bytes.length != 12) {
        throw new IllegalArgumentException("INT96 must be 12 bytes");
    }

    ByteBuffer buffer = ByteBuffer.wrap(bytes)
            .order(ByteOrder.LITTLE_ENDIAN);

    long nanosOfDay = buffer.getLong();
    int julianDay = buffer.getInt();

    long epochDay = julianDay - 2440588L;
    long seconds = epochDay * 86400L
            + (nanosOfDay / 1_000_000_000L);

    return seconds * 1_000_000L
            + ((nanosOfDay % 1_000_000_000L) / 1_000L);
}
