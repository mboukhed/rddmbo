CREATE TABLE IF NOT EXISTS run
(
    run_id String,
    application_id Nullable(String),
    application_name Nullable(String),
    job_name Nullable(String),
    step_name Nullable(String),

    status String,

    start_time Nullable(DateTime64(3)),
    end_time Nullable(DateTime64(3)),

    message Nullable(String),

    environment Nullable(String),
    spark_master Nullable(String),
    driver_host Nullable(String),

    steps_conf_map String
)
ENGINE = MergeTree
ORDER BY (run_id);
