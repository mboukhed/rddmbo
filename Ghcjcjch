import org.apache.spark.sql.types.DataType;
import org.apache.spark.sql.types.StructType;

import java.io.InputStream;
import java.nio.charset.StandardCharsets;

public static StructType loadSchemaFromResources(String path) {
    try (InputStream is = Thread.currentThread()
            .getContextClassLoader()
            .getResourceAsStream(path)) {

        if (is == null) {
            throw new RuntimeException("Schema file not found: " + path);
        }

        String json = new String(is.readAllBytes(), StandardCharsets.UTF_8);

        return (StructType) DataType.fromJson(json);

    } catch (Exception e) {
        throw new RuntimeException("Error loading schema: " + path, e);
    }
}
