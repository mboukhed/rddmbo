Proxy proxy = new Proxy(
        Proxy.Type.SOCKS,
        new InetSocketAddress(proxyHost, 443)
);

try (Socket socket = new Socket(proxy)) {

    socket.connect(
            new InetSocketAddress("login.microsoftonline.com", 443),
            5000
    );

    System.out.println("SOCKS5 Proxy OK");

} catch (Exception e) {

    System.out.println("SOCKS5 Proxy KO");
    e.printStackTrace();
}
