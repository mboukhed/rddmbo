Voici une classe complète SparkMetricsListener avec les métriques utiles.
Java
import org.apache.spark.scheduler.*;
import org.apache.spark.executor.TaskMetrics;
import org.apache.spark.shuffle.ShuffleReadMetrics;
import org.apache.spark.shuffle.ShuffleWriteMetrics;

import java.util.concurrent.atomic.AtomicLong;

public class SparkMetricsListener extends SparkListener {

    private final Run run;

    private final AtomicLong inputBytes = new AtomicLong();
    private final AtomicLong inputRecords = new AtomicLong();
    private final AtomicLong outputBytes = new AtomicLong();
    private final AtomicLong outputRecords = new AtomicLong();

    private final AtomicLong shuffleReadBytes = new AtomicLong();
    private final AtomicLong shuffleReadRecords = new AtomicLong();
    private final AtomicLong shuffleWriteBytes = new AtomicLong();
    private final AtomicLong shuffleWriteRecords = new AtomicLong();

    private final AtomicLong memorySpilled = new AtomicLong();
    private final AtomicLong diskSpilled = new AtomicLong();
    private final AtomicLong executorRunTime = new AtomicLong();
    private final AtomicLong executorCpuTime = new AtomicLong();
    private final AtomicLong jvmGcTime = new AtomicLong();
    private final AtomicLong peakExecutionMemory = new AtomicLong();

    private final AtomicLong tasksCount = new AtomicLong();
    private final AtomicLong tasksFailed = new AtomicLong();
    private final AtomicLong stagesCount = new AtomicLong();
    private final AtomicLong jobsCount = new AtomicLong();

    public SparkMetricsListener(Run run) {
        this.run = run;
    }

    @Override
    public void onJobStart(SparkListenerJobStart jobStart) {
        jobsCount.incrementAndGet();
    }

    @Override
    public void onStageCompleted(SparkListenerStageCompleted stageCompleted) {
        stagesCount.incrementAndGet();
    }

    @Override
    public void onTaskEnd(SparkListenerTaskEnd taskEnd) {
        tasksCount.incrementAndGet();

        if (!"Success".equalsIgnoreCase(taskEnd.reason().toString())) {
            tasksFailed.incrementAndGet();
        }

        TaskMetrics m = taskEnd.taskMetrics();
        if (m == null) return;

        inputBytes.addAndGet(m.inputMetrics().bytesRead());
        inputRecords.addAndGet(m.inputMetrics().recordsRead());

        outputBytes.addAndGet(m.outputMetrics().bytesWritten());
        outputRecords.addAndGet(m.outputMetrics().recordsWritten());

        ShuffleReadMetrics sr = m.shuffleReadMetrics();
        if (sr != null) {
            shuffleReadBytes.addAndGet(sr.remoteBytesRead() + sr.localBytesRead());
            shuffleReadRecords.addAndGet(sr.recordsRead());
        }

        ShuffleWriteMetrics sw = m.shuffleWriteMetrics();
        if (sw != null) {
            shuffleWriteBytes.addAndGet(sw.bytesWritten());
            shuffleWriteRecords.addAndGet(sw.recordsWritten());
        }

        memorySpilled.addAndGet(m.memoryBytesSpilled());
        diskSpilled.addAndGet(m.diskBytesSpilled());
        executorRunTime.addAndGet(m.executorRunTime());
        executorCpuTime.addAndGet(m.executorCpuTime());
        jvmGcTime.addAndGet(m.jvmGCTime());
        peakExecutionMemory.addAndGet(m.peakExecutionMemory());
    }

    @Override
    public void onJobEnd(SparkListenerJobEnd jobEnd) {
        run.addNav("spark.input.bytes", inputBytes.get());
        run.addNav("spark.input.records", inputRecords.get());
        run.addNav("spark.output.bytes", outputBytes.get());
        run.addNav("spark.output.records", outputRecords.get());

        run.addNav("spark.shuffle.read.bytes", shuffleReadBytes.get());
        run.addNav("spark.shuffle.read.records", shuffleReadRecords.get());
        run.addNav("spark.shuffle.write.bytes", shuffleWriteBytes.get());
        run.addNav("spark.shuffle.write.records", shuffleWriteRecords.get());

        run.addNav("spark.memory.spilled", memorySpilled.get());
        run.addNav("spark.disk.spilled", diskSpilled.get());
        run.addNav("spark.executor.run.time.ms", executorRunTime.get());
        run.addNav("spark.executor.cpu.time.ns", executorCpuTime.get());
        run.addNav("spark.jvm.gc.time.ms", jvmGcTime.get());
        run.addNav("spark.peak.execution.memory", peakExecutionMemory.get());

        run.addNav("spark.tasks.count", tasksCount.get());
        run.addNav("spark.tasks.failed", tasksFailed.get());
        run.addNav("spark.stages.count", stagesCount.get());
        run.addNav("spark.jobs.count", jobsCount.get());
        run.addNav("spark.job.status", jobEnd.jobResult().toString());
    }
}
