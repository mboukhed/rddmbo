    static final class FakeBatchWrite implements BatchWrite, Serializable {

        private final String path;
        private final StructType schema;
        private final boolean overwrite;

        FakeBatchWrite(String path, StructType schema, boolean overwrite) {
            this.path = path;
            this.schema = schema;
            this.overwrite = overwrite;
        }

        @Override
        public DataWriterFactory createBatchWriterFactory(PhysicalWriteInfo info) {
            return new FakeDataWriterFactory(path, schema);
        }

        @Override
        public void commit(WriterCommitMessage[] messages) {
            SparkSession spark = spark();

            List<String> chunkPaths = new ArrayList<String>();
            for (WriterCommitMessage msg : messages) {
                FakeWriterCommitMessage m = (FakeWriterCommitMessage) msg;
                chunkPaths.addAll(m.tempPaths);
            }

            if (chunkPaths.isEmpty()) {
                return;
            }

            String finalTmp = path + ".__final_tmp__" + UUID.randomUUID().toString().replace("-", "");

            Dataset<Row> merged = spark.read()
                    .schema(schema)
                    .parquet(chunkPaths.toArray(new String[0]));

            merged.write()
                    .mode(SaveMode.Overwrite)
                    .parquet(finalTmp);

            try {
                Path target = Paths.get(path);
                Path tmp = Paths.get(finalTmp);

                if (overwrite || !Files.exists(target)) {
                    deleteRecursively(target);
                    Files.move(tmp, target, StandardCopyOption.REPLACE_EXISTING);
                } else {
                    String appendTmp = path + ".__append_tmp__" + UUID.randomUUID().toString().replace("-", "");

                    spark.read()
                            .schema(schema)
                            .parquet(path, finalTmp)
                            .write()
                            .mode(SaveMode.Overwrite)
                            .parquet(appendTmp);

                    deleteRecursively(target);
                    Files.move(Paths.get(appendTmp), target, StandardCopyOption.REPLACE_EXISTING);
                    deleteRecursively(tmp);
                }

                for (String chunkPath : chunkPaths) {
                    deleteRecursively(Paths.get(chunkPath));
                }
            } catch (IOException e) {
                throw new RuntimeException(e);
            }
        }

        @Override
        public void abort(WriterCommitMessage[] messages) {
            for (WriterCommitMessage msg : messages) {
                FakeWriterCommitMessage m = (FakeWriterCommitMessage) msg;
                for (String p : m.tempPaths) {
                    deleteRecursively(Paths.get(p));
                }
            }
        }
    }

