    static final class FakeDataWriter implements DataWriter<InternalRow>, Serializable {

        private final String tempBasePath;
        private final StructType schema;
        private final List<Row> buffer = new ArrayList<Row>();
        private final List<String> chunkPaths = new ArrayList<String>();
        private int chunkIndex = 0;

        FakeDataWriter(String basePath, StructType schema, int partitionId, long taskId) {
            this.schema = schema;
            this.tempBasePath = basePath + ".__writer_tmp__" + partitionId + "_" + taskId + "_" +
                    UUID.randomUUID().toString().replace("-", "");
        }

        @Override
        public void write(InternalRow record) {
            Seq<Object> seq = record.toSeq(schema);
            List<Object> values = JavaConverters.seqAsJavaList(seq);
            buffer.add(RowFactory.create(values.toArray()));

            if (buffer.size() >= FLUSH_SIZE) {
                flushBuffer();
            }
        }

        @Override
        public WriterCommitMessage commit() {
            flushBuffer();
            return new FakeWriterCommitMessage(new ArrayList<String>(chunkPaths));
        }

        @Override
        public void abort() {
            for (String p : chunkPaths) {
                deleteRecursively(Paths.get(p));
            }
        }

        @Override
        public void close() {
        }

        private void flushBuffer() {
            if (buffer.isEmpty()) {
                return;
            }

            String chunkPath = tempBasePath + "_chunk_" + (chunkIndex++);
            spark().createDataFrame(buffer, schema)
                    .write()
                    .mode(SaveMode.Overwrite)
                    .parquet(chunkPath);

            chunkPaths.add(chunkPath);
            buffer.clear();
        }
    }

    static final class FakeWriterCommitMessage implements WriterCommitMessage, Serializable {
        final List<String> tempPaths;

        FakeWriterCommitMessage(List<String> tempPaths) {
            this.tempPaths = tempPaths;
        }
    }
}
Le point important : cette version corrige surtout le write.
Le read reste acceptable pour test, mais pas parfait DSv2.
La prochaine vraie amélioration serait de supprimer aussi toLocalIterator() côté read.
