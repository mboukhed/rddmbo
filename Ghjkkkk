4. FakePartitionReader
Java
static final class FakePartitionReader implements PartitionReader<InternalRow> {

    private final StructType schema;
    private final org.apache.parquet.hadoop.ParquetReader<org.apache.avro.generic.GenericRecord> reader;
    private InternalRow current;

    FakePartitionReader(String filePath, StructType schema) {
        this.schema = schema;
        try {
            org.apache.hadoop.conf.Configuration conf = new org.apache.hadoop.conf.Configuration();
            org.apache.hadoop.fs.Path p = new org.apache.hadoop.fs.Path("file:///" + filePath.replace("\\", "/"));

            this.reader = org.apache.parquet.avro.AvroParquetReader
                    .<org.apache.avro.generic.GenericRecord>builder(p)
                    .withConf(conf)
                    .build();
        } catch (IOException e) {
            throw new RuntimeException(e);
        }
    }

    @Override
    public boolean next() {
        try {
            org.apache.avro.generic.GenericRecord record = reader.read();
            if (record == null) {
                return false;
            }

            StructField[] fields = schema.fields();
            Object[] values = new Object[fields.length];

            for (int i = 0; i < fields.length; i++) {
                values[i] = toCatalyst(record.get(fields[i].name()), fields[i].dataType());
            }

            current = new GenericInternalRow(values);
            return true;
        } catch (IOException e) {
            throw new RuntimeException(e);
        }
    }

    @Override
    public InternalRow get() {
        return current;
    }

    @Override
    public void close() {
        try {
            reader.close();
        } catch (IOException e) {
            throw new RuntimeException(e);
        }
    }
}
5. toCatalyst(...)
Garde au minimum ça :
Java
private static Object toCatalyst(Object v, DataType dataType) {
    if (v == null) return null;

    if (v instanceof org.apache.avro.util.Utf8) {
        return UTF8String.fromString(v.toString());
    }

    if (v instanceof String) {
        return UTF8String.fromString((String) v);
    }

    if (v instanceof Integer || v instanceof Long || v instanceof Double
            || v instanceof Float || v instanceof Boolean || v instanceof Short
            || v instanceof Byte) {
        return v;
    }

    return v;
}
