private static void clean(JsonNode node) {
    if (node == null) {
        return;
    }

    if (node.isObject()) {
        ObjectNode obj = (ObjectNode) node;

        List<String> fieldNames = new ArrayList<>();
        obj.fieldNames().forEachRemaining(fieldNames::add);

        for (String oldKey : fieldNames) {
            JsonNode child = obj.get(oldKey);

            // récursion d'abord
            clean(child);

            String newKey = isNumericKey(oldKey)
                    ? oldKey
                    : oldKey.replace(".", "__");

            if (!newKey.equals(oldKey)) {
                obj.remove(oldKey);
                obj.set(newKey, child);
            }
        }
        return;
    }

    if (node.isArray()) {
        for (JsonNode item : node) {
            clean(item);
        }
    }
}

private static boolean isNumericKey(String key) {
    return key != null && key.matches("[+-]?\\d+(\\.\\d+)?");
}
