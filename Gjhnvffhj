4) renameTable
Java
@Override
public void renameTable(Identifier oldIdent, Identifier newIdent) throws NoSuchTableException {
    String oldKey = key(oldIdent);
    String newKey = key(newIdent);

    if (!SCHEMAS.containsKey(oldKey)) {
        throw new NoSuchTableException(oldIdent);
    }

    SCHEMAS.put(newKey, SCHEMAS.remove(oldKey));
    DATA.put(newKey, DATA.remove(oldKey));
}
