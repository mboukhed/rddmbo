    static final class FakeBatchWrite implements BatchWrite, Serializable {

        private final String path;
        private final StructType schema;
        private final String[] partitions;
        private final boolean overwrite;

        FakeBatchWrite(String path, StructType schema, String[] partitions, boolean overwrite) {
            this.path = path;
            this.schema = schema;
            this.partitions = partitions == null ? new String[0] : partitions;
            this.overwrite = overwrite;
        }

        @Override
        public DataWriterFactory createBatchWriterFactory(PhysicalWriteInfo info) {
            return new FakeDataWriterFactory(path, schema);
        }

        @Override
        public void commit(WriterCommitMessage[] messages) {
            List<String> files = new ArrayList<String>();

            for (WriterCommitMessage msg : messages) {
                if (msg == null) continue;
                FakeWriterCommitMessage m = (FakeWriterCommitMessage) msg;
                files.add(m.tempFile);
            }

            if (files.isEmpty()) {
                return;
            }

            SparkSession spark = spark();

            Dataset<Row> df = spark.read()
                    .schema(schema)
                    .json(files.toArray(new String[0]));

            String tmpOut = path + ".__commit_tmp__" + UUID.randomUUID().toString().replace("-", "");

            DataFrameWriter<Row> writer = df.write();
            if (partitions.length > 0) {
                writer = writer.partitionBy(partitions);
            }

            writer.mode(SaveMode.Overwrite).parquet(tmpOut);

            try {
                Path target = Paths.get(path);
                Path tmp = Paths.get(tmpOut);

                if (overwrite || !Files.exists(target)) {
                    deleteRecursively(target);
                    Files.move(tmp, target, StandardCopyOption.REPLACE_EXISTING);
                } else {
                    String appendTmp = path + ".__append_tmp__" + UUID.randomUUID().toString().replace("-", "");

                    Dataset<Row> merged = spark.read().schema(schema).parquet(path, tmpOut);

                    DataFrameWriter<Row> mergedWriter = merged.write();
                    if (partitions.length > 0) {
                        mergedWriter = mergedWriter.partitionBy(partitions);
                    }

                    mergedWriter.mode(SaveMode.Overwrite).parquet(appendTmp);

                    deleteRecursively(target);
                    Files.move(Paths.get(appendTmp), target, StandardCopyOption.REPLACE_EXISTING);
                    deleteRecursively(tmp);
                }

                for (String f : files) {
                    Files.deleteIfExists(Paths.get(f));
                }
            } catch (IOException e) {
                throw new RuntimeException(e);
            }
        }

        @Override
        public void abort(WriterCommitMessage[] messages) {
            if (messages == null) return;

            for (WriterCommitMessage msg : messages) {
                if (msg == null) continue;
                FakeWriterCommitMessage m = (FakeWriterCommitMessage) msg;
                try {
                    Files.deleteIfExists(Paths.get(m.tempFile));
                } catch (IOException ignored) {
                }
            }
        }
    }

    static final class FakeDataWriterFactory implements DataWriterFactory, Serializable {
        private final String basePath;
        private final StructType schema;

        FakeDataWriterFactory(String basePath, StructType schema) {
            this.basePath = basePath;
            this.schema = schema;
        }

        @Override
        public DataWriter<InternalRow> createWriter(int partitionId, long taskId) {
            return new FakeDataWriter(basePath, schema, partitionId, taskId);
        }
    }

    static final class FakeDataWriter implements DataWriter<InternalRow>, Serializable {

        private final String tempFile;
        private final StructType schema;
        private final transient BufferedWriter writer;

        FakeDataWriter(String basePath, StructType schema, int partitionId, long taskId) {
            this.schema = schema;
            this.tempFile = basePath + ".__writer_tmp__" + partitionId + "_" + taskId + "_" +
                    UUID.randomUUID().toString().replace("-", "") + ".jsonl";

            try {
                Path p = Paths.get(tempFile);
                Files.createDirectories(p.getParent());
                this.writer = Files.newBufferedWriter(p);
            } catch (IOException e) {
                throw new RuntimeException(e);
            }
        }

        @Override
        public void write(InternalRow row) {
            try {
                writer.write(toJsonLine(row, schema));
                writer.newLine();
            } catch (IOException e) {
                throw new RuntimeException(e);
            }
        }

        @Override
        public WriterCommitMessage commit() {
            try {
                writer.flush();
                writer.close();
                return new FakeWriterCommitMessage(tempFile);
            } catch (IOException e) {
                throw new RuntimeException(e);
            }
        }

        @Override
        public void abort() {
            try { writer.close(); } catch (Exception ignored) {}
            try { Files.deleteIfExists(Paths.get(tempFile)); } catch (Exception ignored) {}
        }

        @Override
        public void close() {
            try { writer.close(); } catch (Exception ignored) {}
        }

        private static String toJsonLine(InternalRow row, StructType schema) {
            return structToJson(row, schema);
        }

        private static String toJsonValue(Object value, DataType dataType) {
            if (value == null || dataType instanceof NullType) {
                return "null";
            }

            if (dataType instanceof UserDefinedType) {
                UserDefinedType<?> udt = (UserDefinedType<?>) dataType;
                return toJsonValue(value, udt.sqlType());
            }

            if (dataType instanceof StringType) {
                return "\"" + escape(asJavaString(value)) + "\"";
            }

            if (dataType instanceof BooleanType
                    || dataType instanceof IntegerType
                    || dataType instanceof LongType
                    || dataType instanceof DoubleType
                    || dataType instanceof FloatType
                    || dataType instanceof ShortType
                    || dataType instanceof ByteType) {
                return String.valueOf(value);
            }

            if (dataType instanceof DecimalType) {
                return decimalToJson(value);
            }

            if (dataType instanceof DateType) {
                return "\"" + escape(formatDate(value)) + "\"";
            }

            if (dataType instanceof TimestampType) {
                return "\"" + escape(formatTimestamp(value)) + "\"";
            }

            if (dataType instanceof BinaryType) {
                return "\"" + Base64.getEncoder().encodeToString(toBytes(value)) + "\"";
            }

            if (dataType instanceof CalendarIntervalType) {
                return "\"" + escape(formatCalendarInterval(value)) + "\"";
            }

            if (dataType instanceof DayTimeIntervalType) {
                return String.valueOf(value);
            }

            if (dataType instanceof YearMonthIntervalType) {
                return String.valueOf(value);
            }

            if (dataType instanceof StructType) {
                return structValueToJson(value, (StructType) dataType);
            }

            if (dataType instanceof ArrayType) {
                return arrayToJson(value, (ArrayType) dataType);
            }

            if (dataType instanceof MapType) {
                return mapToJson(value, (MapType) dataType);
            }

            return "\"" + escape(asJavaString(value)) + "\"";
        }

        private static String structValueToJson(Object value, StructType schema) {
            if (value == null) {
                return "null";
            }

            if (value instanceof InternalRow) {
                return structToJson((InternalRow) value, schema);
            }

            if (value instanceof Row) {
                Row row = (Row) value;
                StringBuilder sb = new StringBuilder();
                sb.append("{");

                StructField[] fields = schema.fields();
                for (int i = 0; i < fields.length; i++) {
                    if (i > 0) {
                        sb.append(",");
                    }
                    sb.append("\"").append(escape(fields[i].name())).append("\":");
                    Object v = row.isNullAt(i) ? null : row.get(i);
                    sb.append(toJsonValue(v, fields[i].dataType()));
                }

                sb.append("}");
                return sb.toString();
            }

            if (value instanceof Map) {
                @SuppressWarnings("unchecked")
                Map<Object, Object> map = (Map<Object, Object>) value;

                StringBuilder sb = new StringBuilder();
                sb.append("{");

                StructField[] fields = schema.fields();
                for (int i = 0; i < fields.length; i++) {
                    if (i > 0) {
                        sb.append(",");
                    }
                    sb.append("\"").append(escape(fields[i].name())).append("\":");
                    Object v = map.get(fields[i].name());
                    sb.append(toJsonValue(v, fields[i].dataType()));
                }

                sb.append("}");
                return sb.toString();
            }

            return "\"" + escape(asJavaString(value)) + "\"";
        }

        private static String structToJson(InternalRow row, StructType schema) {
            if (row == null) {
                return "null";
            }

            StringBuilder sb = new StringBuilder();
            sb.append("{");

            StructField[] fields = schema.fields();
            for (int i = 0; i < fields.length; i++) {
                if (i > 0) {
                    sb.append(",");
                }

                sb.append("\"").append(escape(fields[i].name())).append("\":");

                if (row.isNullAt(i)) {
                    sb.append("null");
                } else {
                    Object v = row.get(i, fields[i].dataType());
                    sb.append(toJsonValue(v, fields[i].dataType()));
                }
            }

            sb.append("}");
            return sb.toString();
        }

        private static String arrayToJson(Object value, ArrayType arrayType) {
            if (value == null) {
                return "null";
            }

            StringBuilder sb = new StringBuilder();
            sb.append("[");

            boolean first = true;

            if (value instanceof ArrayData) {
                ArrayData ad = (ArrayData) value;

                for (int i = 0; i < ad.numElements(); i++) {
                    if (!first) {
                        sb.append(",");
                    }
                    first = false;

                    Object element = ad.isNullAt(i) ? null : ad.get(i, arrayType.elementType());
                    sb.append(toJsonValue(element, arrayType.elementType()));
                }
            } else if (value instanceof List) {
                List<?> list = (List<?>) value;

                for (Object element : list) {
                    if (!first) {
                        sb.append(",");
                    }
                    first = false;

                    sb.append(toJsonValue(element, arrayType.elementType()));
                }
            } else if (value instanceof Object[]) {
                Object[] arr = (Object[]) value;

                for (Object element : arr) {
                    if (!first) {
                        sb.append(",");
                    }
                    first = false;

                    sb.append(toJsonValue(element, arrayType.elementType()));
                }
            } else {
                return "[]";
            }

            sb.append("]");
            return sb.toString();
        }

        private static String mapToJson(Object value, MapType mapType) {
            if (value == null) {
                return "null";
            }

            StringBuilder sb = new StringBuilder();
            sb.append("{");

            boolean first = true;

            if (value instanceof MapData) {
                MapData md = (MapData) value;

                ArrayData keys = md.keyArray();
                ArrayData vals = md.valueArray();

                for (int i = 0; i < md.numElements(); i++) {
                    if (!first) {
                        sb.append(",");
                    }
                    first = false;

                    Object k = keys.get(i, mapType.keyType());
                    Object v = vals.isNullAt(i) ? null : vals.get(i, mapType.valueType());

                    sb.append("\"").append(escape(asJavaString(k))).append("\":");
                    sb.append(toJsonValue(v, mapType.valueType()));
                }
            } else if (value instanceof Map) {
                @SuppressWarnings("unchecked")
                Map<Object, Object> map = (Map<Object, Object>) value;

                for (Map.Entry<Object, Object> e : map.entrySet()) {
                    if (!first) {
                        sb.append(",");
                    }
                    first = false;

                    sb.append("\"").append(escape(asJavaString(e.getKey()))).append("\":");
                    sb.append(toJsonValue(e.getValue(), mapType.valueType()));
                }
            } else {
                return "{}";
            }

            sb.append("}");
            return sb.toString();
        }

        private static String decimalToJson(Object value) {
            if (value == null) {
                return "null";
            }

            if (value instanceof Decimal) {
                return ((Decimal) value).toJavaBigDecimal().toPlainString();
            }

            if (value instanceof BigDecimal) {
                return ((BigDecimal) value).toPlainString();
            }

            if (value instanceof java.math.BigInteger) {
                return new BigDecimal((java.math.BigInteger) value).toPlainString();
            }

            if (value instanceof Number) {
                return BigDecimal.valueOf(((Number) value).doubleValue()).toPlainString();
            }

            return "\"" + escape(asJavaString(value)) + "\"";
        }

        private static String formatDate(Object value) {
            if (value == null) {
                return null;
            }

            if (value instanceof Integer) {
                return LocalDate.ofEpochDay((Integer) value).toString();
            }

            if (value instanceof Date) {
                return ((Date) value).toLocalDate().toString();
            }

            if (value instanceof LocalDate) {
                return value.toString();
            }

            return asJavaString(value);
        }

        private static String formatTimestamp(Object value) {
            if (value == null) {
                return null;
            }

            if (value instanceof Long) {
                long micros = (Long) value;
                long seconds = micros / 1_000_000L;
                long microsRemainder = micros % 1_000_000L;
                if (microsRemainder < 0) {
                    microsRemainder += 1_000_000L;
                    seconds -= 1;
                }
                Instant instant = Instant.ofEpochSecond(seconds, microsRemainder * 1000L);
                return instant.toString();
            }

            if (value instanceof Timestamp) {
                return ((Timestamp) value).toInstant().toString();
            }

            if (value instanceof Instant) {
                return value.toString();
            }

            return asJavaString(value);
        }

        private static String formatCalendarInterval(Object value) {
            if (value == null) {
                return null;
            }

            if (value instanceof CalendarInterval) {
                CalendarInterval ci = (CalendarInterval) value;
                return "months=" + ci.months + ",days=" + ci.days + ",microseconds=" + ci.microseconds;
            }

            return asJavaString(value);
        }

        private static byte[] toBytes(Object value) {
            if (value instanceof byte[]) {
                return (byte[]) value;
            }

            if (value instanceof UTF8String) {
                return value.toString().getBytes(StandardCharsets.UTF_8);
            }

            if (value instanceof String) {
                return ((String) value).getBytes(StandardCharsets.UTF_8);
            }

            return asJavaString(value).getBytes(StandardCharsets.UTF_8);
        }

        private static String asJavaString(Object value) {
            if (value == null) {
                return null;
            }

            if (value instanceof UTF8String) {
                return value.toString();
            }

            if (value instanceof Decimal) {
                return ((Decimal) value).toJavaBigDecimal().toPlainString();
            }

            return String.valueOf(value);
        }

        private static String escape(String s) {
            if (s == null) {
                return "";
            }

            return s
                    .replace("\\", "\\\\")
                    .replace("\"", "\\\"")
                    .replace("\n", "\\n")
                    .replace("\r", "\\r")
                    .replace("\t", "\\t");
        }
    }

    static final class FakeWriterCommitMessage implements WriterCommitMessage, Serializable {
        final String tempFile;

        FakeWriterCommitMessage(String tempFile) {
            this.tempFile = tempFile;
        }
    }
