    static final class FakePartitionReader implements PartitionReader<InternalRow> {

        private final Iterator<Row> it;
        private final StructType schema;
        private InternalRow current;

        FakePartitionReader(String path, StructType schema) {
            this.schema = schema;
            Dataset<Row> df = spark()
                    .read()
                    .schema(schema)
                    .parquet(path);
            this.it = df.toLocalIterator();
        }

        @Override
        public boolean next() {
            if (!it.hasNext()) {
                return false;
            }

            Row r = it.next();
            StructField[] fields = schema.fields();
            Object[] values = new Object[fields.length];

            for (int i = 0; i < fields.length; i++) {
                values[i] = toCatalyst(r.get(i), fields[i].dataType());
            }

            current = new GenericInternalRow(values);
            return true;
        }

        @Override
        public InternalRow get() {
            return current;
        }

        @Override
        public void close() {
        }

        private static Object toCatalyst(Object v, DataType dataType) {
            if (v == null) {
                return null;
            }

            if (dataType instanceof StructType) {
                StructType st = (StructType) dataType;
                Row row = (Row) v;
                Object[] values = new Object[st.fields().length];

                for (int i = 0; i < st.fields().length; i++) {
                    values[i] = toCatalyst(row.get(i), st.fields()[i].dataType());
                }

                return new GenericInternalRow(values);
            }

            if (dataType instanceof ArrayType) {
                ArrayType at = (ArrayType) dataType;
                List<?> list = (List<?>) v;
                Object[] values = new Object[list.size()];

                for (int i = 0; i < list.size(); i++) {
                    values[i] = toCatalyst(list.get(i), at.elementType());
                }

                return new GenericArrayData(values);
            }

            if (dataType instanceof MapType) {
                MapType mt = (MapType) dataType;
                Map<?, ?> input = (Map<?, ?>) v;

                Object[] keys = new Object[input.size()];
                Object[] vals = new Object[input.size()];

                int i = 0;
                for (Map.Entry<?, ?> e : input.entrySet()) {
                    keys[i] = toCatalyst(e.getKey(), mt.keyType());
                    vals[i] = toCatalyst(e.getValue(), mt.valueType());
                    i++;
                }

                return new ArrayBasedMapData(
                        new GenericArrayData(keys),
                        new GenericArrayData(vals)
                );
            }

            if (v instanceof String) {
                return UTF8String.fromString((String) v);
            }

            if (dataType instanceof DecimalType) {
                DecimalType dt = (DecimalType) dataType;

                if (v instanceof BigDecimal) {
                    return Decimal.apply((BigDecimal) v, dt.precision(), dt.scale());
                }
                if (v instanceof Number) {
                    return Decimal.apply(
                            BigDecimal.valueOf(((Number) v).doubleValue()),
                            dt.precision(),
                            dt.scale()
                    );
                }
            }

            if (v instanceof Date) {
                return (int) ((Date) v).toLocalDate().toEpochDay();
            }

            if (v instanceof LocalDate) {
                return (int) ((LocalDate) v).toEpochDay();
            }

            if (v instanceof Timestamp) {
                Instant instant = ((Timestamp) v).toInstant();
                return instant.getEpochSecond() * 1000000L + instant.getNano() / 1000L;
            }

            if (v instanceof Instant) {
                Instant instant = (Instant) v;
                return instant.getEpochSecond() * 1000000L + instant.getNano() / 1000L;
            }

            return v;
        }
    }

