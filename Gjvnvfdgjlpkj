import org.apache.spark.sql.Column;
import org.apache.spark.sql.Dataset;
import org.apache.spark.sql.Row;

import java.util.*;

import static org.apache.spark.sql.functions.*;

public static Dataset<Row> extractJsonFieldsFromManyColumns(
        Dataset<Row> df,
        Map<String, List<String>> fieldsByJsonColumn
) {
    List<Column> selectCols = new ArrayList<>();

    // garder toutes les colonnes existantes
    for (String c : df.columns()) {
        selectCols.add(col(c));
    }

    // extraire les champs depuis chaque colonne JSON
    for (Map.Entry<String, List<String>> entry : fieldsByJsonColumn.entrySet()) {
        String jsonColumn = entry.getKey();

        for (String field : entry.getValue()) {
            String jsonPath = "$." + field;
            String outputName = jsonColumn + "__" + field.replace(".", "__");

            selectCols.add(
                    get_json_object(col(jsonColumn), jsonPath).alias(outputName)
            );
        }
    }

    return df.select(selectCols.toArray(new Column[0]));
}
