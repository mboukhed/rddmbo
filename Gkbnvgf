import java.nio.file.Files;
import java.nio.file.Paths;
import java.nio.charset.StandardCharsets;

public static void writeSchemaPretty(StructType schema, String outputPath) throws Exception {

    StringBuilder sb = new StringBuilder();
    buildSchemaString(schema, "", sb);

    Files.write(Paths.get(outputPath), sb.toString().getBytes(StandardCharsets.UTF_8));
}
✔ Méthode pour reproduire printSchema()
Java
private static void buildSchemaString(StructType schema, String indent, StringBuilder sb) {

    for (StructField field : schema.fields()) {

        sb.append(indent)
          .append("|-- ")
          .append(field.name())
          .append(": ")
          .append(field.dataType().typeName())
          .append(" (nullable = ")
          .append(field.nullable())
          .append(")\n");

        if (field.dataType() instanceof StructType) {
            buildSchemaString((StructType) field.dataType(), indent + "|   ", sb);
        }
    }
}
