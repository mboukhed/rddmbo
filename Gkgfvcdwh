🔧 Correction de loadSchemaSafe
Java
public static StructType loadSchemaSafe(String path, SparkSession spark) throws IOException {

    String raw;

    if (path.startsWith("abfss://")) {

        org.apache.hadoop.fs.Path hadoopPath = new org.apache.hadoop.fs.Path(path);
        org.apache.hadoop.fs.FileSystem fs =
                hadoopPath.getFileSystem(spark.sparkContext().hadoopConfiguration());

        try (BufferedReader reader = new BufferedReader(
                new InputStreamReader(fs.open(hadoopPath), StandardCharsets.UTF_8)
        )) {
            raw = reader.lines().collect(Collectors.joining());
        }

    } else {
        raw = Files.readString(Paths.get(path));
    }

    raw = raw.trim();

    if (raw.startsWith("\"") && raw.endsWith("\"")) {
        raw = raw.substring(1, raw.length() - 1);
    }

    raw = raw.replace("\\\"", "\"");

    return (StructType) DataType.fromJson(raw);
}
