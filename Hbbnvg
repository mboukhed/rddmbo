public static void writeSchemaPretty(StructType schema, String outputPath, SparkSession spark) throws Exception {

    StringBuilder sb = new StringBuilder();
    buildSchemaString(schema, "", sb);

    if (outputPath.startsWith("abfss://")) {

        org.apache.hadoop.fs.Path path = new org.apache.hadoop.fs.Path(outputPath);
        org.apache.hadoop.fs.FileSystem fs =
                path.getFileSystem(spark.sparkContext().hadoopConfiguration());

        try (BufferedWriter writer = new BufferedWriter(
                new OutputStreamWriter(fs.create(path, true), StandardCharsets.UTF_8)
        )) {
            writer.write(sb.toString());
        }

    } else {
        Files.write(Paths.get(outputPath), sb.toString().getBytes(StandardCharsets.UTF_8));
    }
}
