package it.steps;

import org.apache.spark.sql.connector.catalog.*;
import org.apache.spark.sql.connector.read.*;
import org.apache.spark.sql.connector.write.*;
import org.apache.spark.sql.types.StructType;
import org.apache.spark.sql.util.CaseInsensitiveStringMap;
import org.apache.spark.sql.catalyst.InternalRow;
import org.apache.spark.sql.catalyst.expressions.GenericInternalRow;
import org.apache.spark.unsafe.types.UTF8String;

import java.io.Serializable;
import java.util.*;
import java.util.concurrent.ConcurrentHashMap;

public class FakeClickHouseCatalog implements TableCatalog, SupportsNamespaces {

    private String name;

    private static final Map<String, StructType> SCHEMAS = new ConcurrentHashMap<>();
    private static final Map<String, List<InternalRow>> DATA = new ConcurrentHashMap<>();

    @Override
    public void initialize(String name, CaseInsensitiveStringMap options) {
        this.name = name;
    }

    @Override
    public String name() {
        return name;
    }

    private static String key(Identifier ident) {
        return String.join(".", ident.namespace()) + "." + ident.name();
    }

    public static void clear() {
        SCHEMAS.clear();
        DATA.clear();
    }

    public static void register(String db, String table, StructType schema, List<InternalRow> rows) {
        String k = db + "." + table;
        SCHEMAS.put(k, schema);
        DATA.put(k, new ArrayList<>(rows));
    }

    public static InternalRow row(Object... vals) {
        Object[] v = new Object[vals.length];
        for (int i = 0; i < vals.length; i++) {
            v[i] = vals[i] instanceof String ? UTF8String.fromString((String) vals[i]) : vals[i];
        }
        return new GenericInternalRow(v);
    }

    @Override
    public Table loadTable(Identifier ident) {
        String k = key(ident);
        if (!SCHEMAS.containsKey(k)) throw new RuntimeException("table not found: " + k);
        return new FakeTable(ident, SCHEMAS.get(k), DATA.getOrDefault(k, new ArrayList<>()));
    }

    @Override
    public Table createTable(Identifier ident, StructType schema, Transform[] partitions, Map<String, String> props) {
        String k = key(ident);
        SCHEMAS.put(k, schema);
        DATA.putIfAbsent(k, new ArrayList<>());
        return loadTable(ident);
    }

    @Override public boolean dropTable(Identifier ident) {
        String k = key(ident);
        SCHEMAS.remove(k);
        DATA.remove(k);
        return true;
    }

    @Override public Identifier[] listTables(String[] ns) { return new Identifier[0]; }
    @Override public Table alterTable(Identifier ident, TableChange... changes) { return loadTable(ident); }
    @Override public void renameTable(Identifier oldIdent, Identifier newIdent) {}

    @Override public String[][] listNamespaces() { return new String[0][]; }
    @Override public String[][] listNamespaces(String[] ns) { return new String[0][]; }
    @Override public boolean namespaceExists(String[] ns) { return true; }
    @Override public Map<String, String> loadNamespaceMetadata(String[] ns) { return Map.of(); }
    @Override public void createNamespace(String[] ns, Map<String, String> m) {}
    @Override public void alterNamespace(String[] ns, NamespaceChange... c) {}
    @Override public boolean dropNamespace(String[] ns, boolean cascade) { return true; }

    @Override
    public Set<TableCatalogCapability> capabilities() {
        return EnumSet.of(TableCatalogCapability.BATCH_READ, TableCatalogCapability.BATCH_WRITE);
    }

    // ================= TABLE =================

    static class FakeTable implements Table, SupportsRead, SupportsWrite {

        private final Identifier ident;
        private final StructType schema;
        private final List<InternalRow> rows;

        FakeTable(Identifier ident, StructType schema, List<InternalRow> rows) {
            this.ident = ident;
            this.schema = schema;
            this.rows = rows;
        }

        @Override public String name() { return ident.toString(); }
        @Override public StructType schema() { return schema; }
        @Override public Transform[] partitioning() { return new Transform[0]; }
        @Override public Map<String, String> properties() { return Map.of(); }

        @Override
        public Set<TableCapability> capabilities() {
            return Set.of(TableCapability.BATCH_READ, TableCapability.BATCH_WRITE);
        }

        // READ
        @Override
        public ScanBuilder newScanBuilder(CaseInsensitiveStringMap options) {
            return () -> new FakeScan(schema, rows);
        }

        // WRITE
        @Override
        public WriteBuilder newWriteBuilder(LogicalWriteInfo info) {
            return () -> new FakeBatchWrite(rows);
        }
    }

    // ================= READ =================

    static class FakeScan implements Scan, Batch {

        private final StructType schema;
        private final List<InternalRow> rows;

        FakeScan(StructType schema, List<InternalRow> rows) {
            this.schema = schema;
            this.rows = rows;
        }

        @Override public StructType readSchema() { return schema; }
        @Override public Batch toBatch() { return this; }

        @Override
        public InputPartition[] planInputPartitions() {
            return new InputPartition[]{ new FakePartition(rows) };
        }

        @Override
        public PartitionReaderFactory createReaderFactory() {
            return partition -> new PartitionReader<>() {
                Iterator<InternalRow> it = ((FakePartition) partition).rows.iterator();
                InternalRow current;

                public boolean next() {
                    if (it.hasNext()) { current = it.next(); return true; }
                    return false;
                }

                public InternalRow get() { return current; }
                public void close() {}
            };
        }
    }

    static class FakePartition implements InputPartition, Serializable {
        List<InternalRow> rows;
        FakePartition(List<InternalRow> rows) { this.rows = rows; }
    }

    // ================= WRITE =================

    static class FakeBatchWrite implements BatchWrite {

        private final List<InternalRow> storage;

        FakeBatchWrite(List<InternalRow> storage) {
            this.storage = storage;
        }

        @Override
        public DataWriterFactory createBatchWriterFactory(PhysicalWriteInfo info) {
            return partitionId -> new DataWriter<>() {

                @Override
                public void write(InternalRow record) {
                    storage.add(record);
                }

                @Override public WriterCommitMessage commit() { return null; }
                @Override public void abort() {}
                @Override public void close() {}
            };
        }

        @Override public void commit(WriterCommitMessage[] messages) {}
        @Override public void abort(WriterCommitMessage[] messages) {}
    }
}
🧪 Exemple test
Java
SparkSession spark = SparkSession.builder()
    .master("local[*]")
    .config("spark.sql.catalog.clickhouse", "it.steps.FakeClickHouseCatalog")
    .getOrCreate();

StructType schema = new StructType()
    .add("id", "int")
    .add("name", "string");

FakeClickHouseCatalog.register(
    "mydb",
    "users",
    schema,
    List.of(
        FakeClickHouseCatalog.row(1, "a"),
        FakeClickHouseCatalog.row(2, "b")
    )
);

// WRITE
spark.range(3).selectExpr("id", "'x' as name")
    .writeTo("clickhouse.mydb.users")
    .append();

// READ
long count = spark.sql("select * from clickhouse.mydb.users").count();
System.out.println(count); // 5
