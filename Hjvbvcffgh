package com.example.spark;

import org.apache.spark.api.java.function.FilterFunction;
import org.apache.spark.sql.*;
import org.apache.spark.sql.types.*;

import java.util.ArrayList;
import java.util.List;

import static org.apache.spark.sql.functions.*;

public final class JsonFlattener {

    private static final String SEP = "__";
    private static final int SCHEMA_SAMPLE_SIZE = 10000; // 🔥 ajuste si besoin

    private JsonFlattener() {
    }

    /**
     * Entrée principale optimisée
     */
    public static Dataset<Row> flattenJsonColumn(Dataset<Row> df, String jsonColumn) {

        StructType schema = inferSchemaOptimized(df, jsonColumn);

        // LOG SCHEMA
        System.out.println("==== JSON SCHEMA ====");
        System.out.println(schema.prettyJson());
        System.out.println("=====================");

        return flattenJsonColumn(df, jsonColumn, schema);
    }

    /**
     * Version avec schéma fourni (prod stable)
     */
    public static Dataset<Row> flattenJsonColumn(Dataset<Row> df, String jsonColumn, StructType schema) {

        if (schema == null || schema.fields().length == 0) {
            return df;
        }

        String parsedCol = jsonColumn + "_parsed";

        Dataset<Row> parsed = df.withColumn(parsedCol, from_json(col(jsonColumn), schema));

        List<Column> cols = new ArrayList<Column>();

        for (String c : df.columns()) {
            cols.add(col(c));
        }

        cols.addAll(flattenStruct(col(parsedCol), schema, jsonColumn));

        return parsed.select(cols.toArray(new Column[0]));
    }

    /**
     * 🔥 Inférence optimisée
     * - filtre JSON objet
     * - sample limité
     * - cache temporaire
     */
    private static StructType inferSchemaOptimized(Dataset<Row> df, String jsonColumn) {

        SparkSession spark = df.sparkSession();

        Dataset<String> jsonDs = df
                .select(col(jsonColumn).cast("string"))
                .filter(col(jsonColumn).isNotNull())
                .filter(trim(col(jsonColumn)).notEqual(lit("")))
                .as(Encoders.STRING())
                .filter(new FilterFunction<String>() {
                    @Override
                    public boolean call(String s) {
                        return isJsonObject(s);
                    }
                })
                .limit(SCHEMA_SAMPLE_SIZE)   // 🔥 clé perf
                .cache();

        StructType schema;

        if (jsonDs.isEmpty()) {
            schema = new StructType();
        } else {
            schema = spark.read().json(jsonDs).schema();
        }

        jsonDs.unpersist();

        return schema;
    }

    /**
     * Flatten STRUCT uniquement
     */
    private static List<Column> flattenStruct(Column parentCol, StructType schema, String prefix) {

        List<Column> result = new ArrayList<Column>();

        for (StructField field : schema.fields()) {

            String name = field.name();
            DataType type = field.dataType();

            Column child = parentCol.getField(name);
            String alias = prefix + SEP + name;

            if (type instanceof StructType) {

                StructType struct = (StructType) type;

                if (shouldStop(struct)) {
                    result.add(to_json(child).alias(alias));
                } else {
                    result.addAll(flattenStruct(child, struct, alias));
                }

            } else {
                result.add(child.alias(alias));
            }
        }

        return result;
    }

    /**
     * STOP global
     */
    private static boolean shouldStop(StructType schema) {

        for (StructField f : schema.fields()) {
            String n = f.name();

            if (isNumeric(n) || hasMoreThanOneDigit(n)) {
                return true;
            }
        }
        return false;
    }

    private static boolean isNumeric(String s) {
        return s != null && s.matches("\\d+");
    }

    private static boolean hasMoreThanOneDigit(String s) {
        if (s == null) return false;

        int count = 0;
        for (char c : s.toCharArray()) {
            if (Character.isDigit(c)) {
                count++;
                if (count > 1) return true;
            }
        }
        return false;
    }

    private static boolean isJsonObject(String s) {
        if (s == null) return false;
        String v = s.trim();
        return !v.isEmpty() && v.startsWith("{") && v.endsWith("}");
    }
}
