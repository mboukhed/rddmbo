2. Implémente vraiment deleteWhere
Exemple simple :
Java
@Override
public void deleteWhere(Filter[] filters) {
    if (filters == null || filters.length != 1) {
        throw new UnsupportedOperationException("Only single EqualTo filter is supported");
    }

    Filter filter = filters[0];
    if (!(filter instanceof org.apache.spark.sql.sources.EqualTo)) {
        throw new UnsupportedOperationException("Only EqualTo filter is supported");
    }

    org.apache.spark.sql.sources.EqualTo eq = (org.apache.spark.sql.sources.EqualTo) filter;

    String column = eq.attribute();
    Object value = eq.value();

    List<InternalRow> rows = DATA.get(tableKey);
    StructType schema = SCHEMAS.get(tableKey);

    int fieldIndex = schema.fieldIndex(column);

    List<InternalRow> filtered = new ArrayList<>();
    for (InternalRow row : rows) {
        Object currentValue = row.get(fieldIndex, schema.fields()[fieldIndex].dataType());
        if (!Objects.equals(currentValue, value)) {
            filtered.add(row);
        }
    }

    DATA.put(tableKey, filtered);
}
