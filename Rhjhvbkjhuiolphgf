package com.example.spark;

import org.apache.spark.sql.Dataset;
import org.apache.spark.sql.Encoders;
import org.apache.spark.sql.Row;
import org.apache.spark.sql.SparkSession;
import org.apache.spark.sql.types.StructType;

import static org.apache.spark.sql.functions.col;
import static org.apache.spark.sql.functions.from_json;
import static org.apache.spark.sql.functions.length;
import static org.apache.spark.sql.functions.lit;
import static org.apache.spark.sql.functions.regexp_replace;
import static org.apache.spark.sql.functions.trim;
import static org.apache.spark.sql.functions.when;

public final class JsonColumnParser {

    private JsonColumnParser() {
    }

    public static Dataset<Row> parseJsonColumn(
            SparkSession spark,
            Dataset<Row> df,
            String jsonColumnName,
            String parsedColumnName
    ) {
        Dataset<Row> preparedDf = df
                .withColumn("__raw_json", col(jsonColumnName).cast("string"))
                .withColumn(
                        "__json_cleaned",
                        regexp_replace(
                                regexp_replace(col("__raw_json"), "^\"|\"$", ""),
                                "\\\\\"",
                                "\""
                        )
                )
                .withColumn(
                        "__json_candidate",
                        when(
                                col("__json_cleaned").isNull()
                                        .or(length(trim(col("__json_cleaned"))).equalTo(0)),
                                lit(null)
                        ).when(
                                trim(col("__json_cleaned")).rlike("^\\{.*\\}$|^\\[.*\\]$"),
                                trim(col("__json_cleaned"))
                        ).otherwise(lit(null))
                );

        Dataset<String> jsonDs = preparedDf
                .select(col("__json_candidate"))
                .where(col("__json_candidate").isNotNull())
                .as(Encoders.STRING());

        StructType jsonSchema = spark.read().json(jsonDs).schema();

        return preparedDf
                .withColumn(
                        parsedColumnName,
                        from_json(col("__json_candidate"), jsonSchema)
                )
                .drop("__raw_json", "__json_cleaned", "__json_candidate");
    }
}
