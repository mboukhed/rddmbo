    static final class FakePartitionReader implements PartitionReader<InternalRow> {

        private final StructType schema;
        private final ParquetReader<GenericRecord> reader;
        private InternalRow current;

        FakePartitionReader(String filePath, StructType schema) {
            this.schema = schema;
            try {
                Configuration conf = new Configuration();
                Path path = new Path("file:///" + filePath.replace("\\", "/"));

                this.reader = AvroParquetReader
                        .<GenericRecord>builder(path)
                        .withConf(conf)
                        .build();
            } catch (IOException e) {
                throw new RuntimeException(e);
            }
        }

        @Override
        public boolean next() {
            try {
                GenericRecord record = reader.read();
                if (record == null) {
                    return false;
                }

                StructField[] fields = schema.fields();
                Object[] values = new Object[fields.length];

                for (int i = 0; i < fields.length; i++) {
                    StructField field = fields[i];
                    Object raw = record.get(field.name());
                    values[i] = toCatalyst(raw, field.dataType());
                }

                current = new GenericInternalRow(values);
                return true;
            } catch (IOException e) {
                throw new RuntimeException(e);
            }
        }

        @Override
        public InternalRow get() {
            return current;
        }

        @Override
        public void close() {
            try {
                reader.close();
            } catch (IOException e) {
                throw new RuntimeException(e);
            }
        }

        private static Object toCatalyst(Object v, DataType dataType) {
            if (v == null) {
                return null;
            }

            if (v instanceof Utf8) {
                v = v.toString();
            }

            if (dataType instanceof StructType) {
                StructType st = (StructType) dataType;
                GenericRecord record = (GenericRecord) v;

                Object[] values = new Object[st.fields().length];
                StructField[] fields = st.fields();

                for (int i = 0; i < fields.length; i++) {
                    Object child = record.get(fields[i].name());
                    values[i] = toCatalyst(child, fields[i].dataType());
                }

                return new GenericInternalRow(values);
            }

            if (dataType instanceof ArrayType) {
                ArrayType at = (ArrayType) dataType;
                List<?> input;

                if (v instanceof GenericData.Array) {
                    input = (List<?>) v;
                } else if (v instanceof List) {
                    input = (List<?>) v;
                } else {
                    throw new IllegalArgumentException("Unsupported array value: " + v.getClass());
                }

                Object[] values = new Object[input.size()];
                for (int i = 0; i < input.size(); i++) {
                    values[i] = toCatalyst(input.get(i), at.elementType());
                }

                return new GenericArrayData(values);
            }

            if (dataType instanceof MapType) {
                MapType mt = (MapType) dataType;
                Map<?, ?> input = (Map<?, ?>) v;

                List<Object> keys = new ArrayList<Object>();
                List<Object> values = new ArrayList<Object>();

                for (Map.Entry<?, ?> e : input.entrySet()) {
                    keys.add(toCatalyst(e.getKey(), mt.keyType()));
                    values.add(toCatalyst(e.getValue(), mt.valueType()));
                }

                return new ArrayBasedMapData(
                        new GenericArrayData(keys.toArray()),
                        new GenericArrayData(values.toArray())
                );
            }

            if (v instanceof CharSequence) {
                return UTF8String.fromString(v.toString());
            }

            if (v instanceof Integer || v instanceof Long || v instanceof Double
                    || v instanceof Float || v instanceof Boolean || v instanceof Short
                    || v instanceof Byte) {
                return v;
            }

            if (dataType instanceof DecimalType) {
                DecimalType dt = (DecimalType) dataType;

                if (v instanceof BigDecimal) {
                    return Decimal.apply((BigDecimal) v, dt.precision(), dt.scale());
                }

                if (v instanceof java.math.BigInteger) {
                    return Decimal.apply(new BigDecimal((java.math.BigInteger) v), dt.precision(), dt.scale());
                }

                if (v instanceof Number) {
                    return Decimal.apply(BigDecimal.valueOf(((Number) v).doubleValue()), dt.precision(), dt.scale());
                }
            }

            if (v instanceof java.sql.Date) {
                return (int) ((java.sql.Date) v).toLocalDate().toEpochDay();
            }

            if (v instanceof LocalDate) {
                return (int) ((LocalDate) v).toEpochDay();
            }

            if (v instanceof java.sql.Timestamp) {
                Instant instant = ((java.sql.Timestamp) v).toInstant();
                return instant.getEpochSecond() * 1000000L + instant.getNano() / 1000L;
            }

            if (v instanceof Instant) {
                Instant instant = (Instant) v;
                return instant.getEpochSecond() * 1000000L + instant.getNano() / 1000L;
            }

            if (v instanceof java.util.Date) {
                Instant instant = ((java.util.Date) v).toInstant();
                return instant.getEpochSecond() * 1000000L + instant.getNano() / 1000L;
            }

            return v;
        }
    }

    static final class FakeWriteBuilder implements WriteBuilder, SupportsOverwrite, SupportsTruncate, Serializable {

        private final String path;
        private final StructType schema;
        private boolean overwrite;

        FakeWriteBuilder(String path, StructType schema) {
            this.path = path;
            this.schema = schema;
        }

        @Override
        public WriteBuilder overwrite(Filter[] filters) {
            this.overwrite = true;
            return this;
        }

        @Override
        public WriteBuilder truncate() {
            this.overwrite = true;
            return this;
        }

        @Override
        public BatchWrite buildForBatch() {
            return new FakeBatchWrite(path, schema, overwrite);
        }
    }

    static final class FakeBatchWrite implements BatchWrite, Serializable {

        private final String path;
        private final StructType schema;
        private final boolean overwrite;

        FakeBatchWrite(String path, StructType schema, boolean overwrite) {
            this.path = path;
            this.schema = schema;
            this.overwrite = overwrite;
        }

        @Override
        public DataWriterFactory createBatchWriterFactory(PhysicalWriteInfo info) {
            return new FakeDataWriterFactory();
        }

        @Override
        public void commit(WriterCommitMessage[] messages) {
            List<Row> rows = new ArrayList<Row>();

            for (WriterCommitMessage msg : messages) {
                FakeWriterCommitMessage m = (FakeWriterCommitMessage) msg;
                for (InternalRow r : m.rows) {
                    Seq<Object> seq = r.toSeq(schema);
                    List<Object> values = JavaConverters.seqAsJavaList(seq);
                    rows.add(RowFactory.create(values.toArray()));
                }
            }

            spark().createDataFrame(rows, schema)
                    .write()
                    .mode(overwrite ? SaveMode.Overwrite : SaveMode.Append)
                    .parquet(path);
        }

        @Override
        public void abort(WriterCommitMessage[] messages) {
        }
    }

    static final class FakeDataWriterFactory implements DataWriterFactory, Serializable {
        @Override
        public DataWriter<InternalRow> createWriter(int partitionId, long taskId) {
            return new FakeDataWriter();
        }
    }

    static final class FakeDataWriter implements DataWriter<InternalRow>, Serializable {

        private final List<InternalRow> buffer = new ArrayList<InternalRow>();

        @Override
        public void write(InternalRow record) {
            buffer.add(record.copy());
        }

        @Override
        public WriterCommitMessage commit() {
            return new FakeWriterCommitMessage(buffer);
        }

        @Override
        public void abort() {
        }

        @Override
        public void close() {
        }
    }

    static final class FakeWriterCommitMessage implements WriterCommitMessage, Serializable {
        final List<InternalRow> rows;

        FakeWriterCommitMessage(List<InternalRow> rows) {
            this.rows = rows;
        }
    }
