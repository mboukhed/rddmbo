package com.example.spark;

import org.apache.spark.sql.Dataset;
import org.apache.spark.sql.Row;
import org.apache.spark.sql.types.ArrayType;
import org.apache.spark.sql.types.DataType;
import org.apache.spark.sql.types.StructType;

import java.util.List;

import static org.apache.spark.sql.functions.col;
import static org.apache.spark.sql.functions.explode_outer;

public final class ArrayStructExploder {

    private ArrayStructExploder() {
    }

    public static Dataset<Row> explodeArrayStructColumn(
            Dataset<Row> df,
            String arrayColumnName
    ) {
        String tempItemColumn = "__temp_array_item";

        DataType dataType = df.schema().apply(arrayColumnName).dataType();

        if (!(dataType instanceof ArrayType)) {
            throw new IllegalArgumentException(
                    "Column [" + arrayColumnName + "] is not array. Actual type = "
                            + dataType.simpleString()
            );
        }

        ArrayType arrayType = (ArrayType) dataType;

        if (!(arrayType.elementType() instanceof StructType)) {
            throw new IllegalArgumentException(
                    "Column [" + arrayColumnName + "] is not array<struct>. Actual type = "
                            + dataType.simpleString()
            );
        }

        Dataset<Row> explodedDf = df.withColumn(
                tempItemColumn,
                explode_outer(col(escape(arrayColumnName)))
        );

        Dataset<Row> resultDf = SparkStructFlattener.flattenStructColumnWithAliasPrefix(
                explodedDf,
                tempItemColumn,
                arrayColumnName
        );

        return resultDf.drop(tempItemColumn);
    }

    public static Dataset<Row> explodeArrayStructColumns(
            Dataset<Row> df,
            List<String> arrayColumnNames
    ) {
        Dataset<Row> result = df;

        for (String arrayColumnName : arrayColumnNames) {
            result = explodeArrayStructColumn(result, arrayColumnName);
        }

        return result;
    }

    private static String escape(String name) {
        return "`" + name.replace("`", "``") + "`";
    }
}
