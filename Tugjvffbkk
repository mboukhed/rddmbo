import com.fasterxml.jackson.databind.JsonNode;
import com.fasterxml.jackson.databind.ObjectMapper;
import com.fasterxml.jackson.databind.node.ObjectNode;
import org.apache.spark.api.java.function.MapPartitionsFunction;
import org.apache.spark.sql.Dataset;
import org.apache.spark.sql.Encoders;
import org.apache.spark.sql.Row;
import org.apache.spark.sql.RowFactory;
import org.apache.spark.sql.catalyst.encoders.RowEncoder;
import org.apache.spark.sql.types.StructField;
import org.apache.spark.sql.types.StructType;

import java.util.ArrayList;
import java.util.Iterator;
import java.util.List;
import java.util.Map;

public final class JsonCleanerHelper {

    private JsonCleanerHelper() {
    }

    public static Dataset<Row> cleanUpdatedFields(Dataset<Row> df, String jsonColumn) {
        StructType schema = df.schema();
        int jsonColumnIndex = findColumnIndex(schema, jsonColumn);

        return df.mapPartitions(
                (MapPartitionsFunction<Row, Row>) input -> {
                    ObjectMapper mapper = new ObjectMapper();
                    List<Row> out = new ArrayList<>();

                    while (input.hasNext()) {
                        Row row = input.next();
                        Object[] values = new Object[row.size()];

                        for (int i = 0; i < row.size(); i++) {
                            values[i] = row.get(i);
                        }

                        Object rawJson = row.get(jsonColumnIndex);

                        if (rawJson instanceof String json && json != null && !json.trim().isEmpty()) {
                            try {
                                JsonNode root = mapper.readTree(json);
                                removeUpdatedFieldsRecursively(root);
                                values[jsonColumnIndex] = mapper.writeValueAsString(root);
                            } catch (Exception e) {
                                values[jsonColumnIndex] = json;
                            }
                        }

                        out.add(RowFactory.create(values));
                    }

                    return out.iterator();
                },
                RowEncoder.apply(schema)
        );
    }

    private static int findColumnIndex(StructType schema, String columnName) {
        StructField[] fields = schema.fields();
        for (int i = 0; i < fields.length; i++) {
            if (fields[i].name().equals(columnName)) {
                return i;
            }
        }
        throw new IllegalArgumentException("Colonne introuvable : " + columnName);
    }

    private static void removeUpdatedFieldsRecursively(JsonNode node) {
        if (node == null) {
            return;
        }

        if (node.isObject()) {
            ObjectNode objectNode = (ObjectNode) node;

            List<String> toRemove = new ArrayList<>();
            Iterator<Map.Entry<String, JsonNode>> fields = objectNode.fields();

            while (fields.hasNext()) {
                Map.Entry<String, JsonNode> entry = fields.next();
                String key = entry.getKey();
                JsonNode value = entry.getValue();

                if (containsUpdatedAt(key)) {
                    toRemove.add(key);
                } else {
                    removeUpdatedFieldsRecursively(value);
                }
            }

            for (String key : toRemove) {
                objectNode.remove(key);
            }
        } else if (node.isArray()) {
            for (JsonNode child : node) {
                removeUpdatedFieldsRecursively(child);
            }
        }
    }

    private static boolean containsUpdatedAt(String key) {
        return key != null && key.matches("(?i).*updated\\s*@\\s*.*");
    }
}
