private static String renameKey(String key) {
    if (key == null) {
        return null;
    }

    if (isNumericKey(key)) {
        return key;
    }

    return key.replace(".", "__");
}

private static boolean isNumericKey(String key) {
    return key.matches("[+-]?\\d+(\\.\\d+)?");
}
