YAML
extraEnvVars:
  - name: PATH
    value: "/opt/blocked-bin:/usr/local/sbin:/usr/local/bin:/usr/sbin:/usr/bin:/sbin:/bin"

extraVolumeMounts:
  - name: blocked-commands
    mountPath: /opt/blocked-bin
    readOnly: true

extraVolumes:
  - name: blocked-commands
    configMap:
      name: blocked-commands
      defaultMode: 0555
